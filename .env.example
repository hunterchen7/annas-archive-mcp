# Required
ANNAS_SECRET_KEY=your-anna-archive-membership-api-key

# Postgres
POSTGRES_PASSWORD=change-me-in-production

# Path to downloaded AAC metadata files on the host
AAC_DATA_PATH=/path/to/downloaded/aac-metadata

# Optional: bearer token to protect the HTTP endpoint
AUTH_TOKEN=some-random-secret

# Optional: Anna's Archive mirror to use
ANNAS_BASE_URL=annas-archive.gl

# Transport mode: "http" for remote access, "stdio" for local Claude Code
TRANSPORT=http
